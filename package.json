{
  "name": "links-v2",
  "version": "0.0.0",
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=22.19.0",
    "npm": ">=10.9.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:analyze": "ng build --configuration production --stats-json --progress=false",
    "watch": "ng build --watch --configuration development",
    "test": "npm run test:unit",
    "lint": "eslint \"src/**/*.ts\" \"libs/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"libs/**/*.ts\" --fix",
    "lint:html": "eslint \"src/**/*.html\" \"libs/**/*.html\"",
    "docs:check-links": "node scripts/check-markdown-links.mjs",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss,json}\" \"libs/**/*.{ts,html,css,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,scss,json}\" \"libs/**/*.{ts,html,css,scss,json}\"",
    "type-check": "tsc -p tsconfig.typecheck.json",
    "check": "npm run format:check && npm run lint && npm run lint:html && npm run type-check",
    "fix": "npm run format && npm run lint:fix",
    "api:generate": "npm run api:generate:auth && npm run api:generate:links && npm run api:postgen",
    "api:generate:auth": "ng-openapi-gen -c src/api/ng-openapi-gen-auth.json",
    "api:generate:links": "ng-openapi-gen -c src/api/ng-openapi-gen-links.json",
    "api:postgen": "node scripts/api-postgen.mjs",
    "storybook": "ng run links-v2:storybook",
    "build-storybook": "ng run links-v2:build-storybook",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:i18n": "playwright test e2e/i18n-language.spec.ts",
    "test:stories": "test-storybook --config-dir .storybook",
    "test:stories:watch": "test-storybook --config-dir .storybook --watch",
    "test:stories:smoke": "test-storybook --config-dir .storybook --excludeTags interaction",
    "test:stories:interaction": "test-storybook --config-dir .storybook --includeTags interaction",
    "test:stories:smoke:ci": "npm run test:stories:smoke -- --ci --url http://127.0.0.1:6006",
    "test:stories:interaction:ci": "npm run test:stories:interaction -- --ci --url http://127.0.0.1:6006",
    "test:stories:ci": "npm run build-storybook && start-server-and-test \"http-server storybook-static --port 6006 --silent\" http://127.0.0.1:6006 \"npm run test:stories:smoke:ci && npm run test:stories:interaction:ci\"",
    "test:unit:ci": "vitest run --coverage",
    "test:ci": "npm run check && npm run test:unit:ci"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~21.1.5",
    "@angular/cdk": "~21.1.5",
    "@angular/common": "~21.1.5",
    "@angular/compiler": "~21.1.5",
    "@angular/core": "~21.1.5",
    "@angular/forms": "~21.1.5",
    "@angular/material": "~21.1.5",
    "@angular/platform-browser": "~21.1.5",
    "@angular/platform-browser-dynamic": "~21.1.5",
    "@angular/router": "~21.1.5",
    "@fontsource-variable/mona-sans": "^5.2.8",
    "@fontsource/material-icons": "^5.2.7",
    "@jsverse/transloco": "^8.2.1",
    "@vitest/browser": "^4.0.18",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2101.4",
    "@angular-devkit/build-angular": "~21.1.4",
    "@angular-devkit/core": "~21.1.4",
    "@angular-eslint/builder": "^21.2.0",
    "@angular-eslint/eslint-plugin": "^21.2.0",
    "@angular-eslint/eslint-plugin-template": "^21.2.0",
    "@angular-eslint/schematics": "^21.2.0",
    "@angular-eslint/template-parser": "^21.2.0",
    "@angular/cli": "~21.1.4",
    "@angular/compiler-cli": "~21.1.5",
    "@anthropic-ai/claude-code": "^2.1.50",
    "@compodoc/compodoc": "^1.2.1",
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/addon-onboarding": "^10.2.10",
    "@storybook/angular": "^10.2.10",
    "@storybook/test-runner": "^0.24.2",
    "@testing-library/angular": "^19.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-storybook": "^10.2.10",
    "http-server": "^14.1.1",
    "jsdom": "^28.1.0",
    "ng-openapi-gen": "^1.0.5",
    "prettier": "^3.8.1",
    "start-server-and-test": "^2.1.3",
    "storybook": "^10.2.10",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
